# BabyNest Backend Environment Variables
# Copy this file to .env and update with your actual values

# JWT Secret Key (Change this to a strong random string)
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/BabyNest

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail)
# IMPORTANT: Use Gmail App Password, not regular password
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password for "Mail" application
# 3. Use the 16-character app password below

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Example:
# EMAIL_USER=babynest.notifications@gmail.com
# EMAIL_PASSWORD=abcd efgh ijkl mnop